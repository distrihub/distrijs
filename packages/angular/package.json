{
  "name": "@distri/angular",
  "version": "0.0.3",
  "description": "Angular SDK for Distri agents \u2014 Signal-based services and chat components, built on @distri/state",
  "keywords": [
    "distri",
    "angular",
    "ai",
    "agents",
    "chat",
    "llm"
  ],
  "license": "MIT",
  "homepage": "https://distri.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/distrihub/distrijs.git",
    "directory": "packages/angular"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "dev": "ng-packagr -p ng-package.json -c tsconfig.lib.json --watch",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "node -e \"console.error('\\n[@distri/angular] Do NOT publish from the package root — it ships a package.json with no entry points (main/module/types), causing \\'cannot resolve @distri/angular\\'.\\nRun `pnpm release` instead, which builds and runs `npm publish ./dist`.\\n'); process.exit(1)\"",
    "release": "pnpm build && npm publish ./dist --access public"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-placeholder": "^3.27.4",
    "@tiptap/starter-kit": "^3.22.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
    "@distri/core": "^0.4.4",
    "@distri/state": "^0.1.0"
  },
  "devDependencies": {
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@distri/core": "workspace:*",
    "@distri/state": "workspace:*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "ng-packagr": "^18.2.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.1"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}