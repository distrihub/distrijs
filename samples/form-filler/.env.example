# Server-side only (NO VITE_ prefix) — these stay in the Vite dev-server
# process and are never inlined into the browser bundle. The dev server
# exchanges DISTRI_API_KEY for a short-lived access token via
# POST {DISTRI_BASE_URL}/token, and only that short-lived token is ever
# sent to the frontend.
DISTRI_API_KEY=
DISTRI_BASE_URL=https://api.distri.dev/v1
# DISTRI_WORKSPACE_ID=

# Optional: where the frontend fetches its token from (default below).
# VITE_DISTRI_TOKEN_ENDPOINT=/api/distri/token
